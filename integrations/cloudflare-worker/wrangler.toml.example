# ─────────────────────────────────────────────
# Cloudflare Worker — wrangler.toml (Template)
# ─────────────────────────────────────────────
# Copy this to wrangler.toml and fill in your values.
# NEVER commit real account IDs or secrets.

name = "my-learning-api"
main = "worker.js"
compatibility_date = "2024-01-01"

# Uncomment and set your account ID:
# account_id = "your-cloudflare-account-id"

# Environment variables (non-secret)
[vars]
ALLOWED_ORIGINS = "https://yourdomain.com,http://localhost:3000"

# For secrets (API keys, etc), use:
#   npx wrangler secret put OPENAI_API_KEY
#   npx wrangler secret put SUPABASE_KEY

# Custom domain routing (optional):
# [routes]
# [{ pattern = "api.yourdomain.com/*", zone_name = "yourdomain.com" }]

# KV Namespace binding (optional):
# [[kv_namespaces]]
# binding = "CACHE"
# id = "your-kv-namespace-id"

# D1 Database binding (optional):
# [[d1_databases]]
# binding = "DB"
# database_name = "my-learning-db"
# database_id = "your-d1-database-id"
